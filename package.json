{
  "name": "taski",
  "displayName": "Taski",
  "description": "Aggregate tasks from markdown files and display them organized by date",
  "version": "0.0.26",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "taski",
          "title": "Taski",
          "icon": "$(checklist)"
        }
      ]
    },
    "views": {
      "taski": [
        {
          "id": "taskiView",
          "name": "タスク一覧"
        },
        {
          "id": "taskiTagView",
          "name": "タグ別"
        }
      ]
    },
    "commands": [
      {
        "command": "taski.showToday",
        "title": "Taski: Show Today's Tasks"
      },
      {
        "command": "taski.refreshTasks",
        "title": "Taski: Refresh Tasks",
        "icon": "$(refresh)"
      },
      {
        "command": "taski.addTodayLog",
        "title": "Taski: Add Today's Log Entry"
      },
      {
        "command": "taski.addTomorrowLog",
        "title": "Taski: Add Tomorrow's Log Entry"
      },
      {
        "command": "taski.toggleTask",
        "title": "Taski: Toggle Task Completion"
      },
      {
        "command": "taski.openTodayJournal",
        "title": "Taski: Open Today's Journal"
      },
      {
        "command": "taski.syncNow",
        "title": "Taski: Sync Now (Git)",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "taski.showSchedule",
        "title": "Taski: Show Schedule Grid",
        "icon": "$(calendar)"
      }
    ],
    "keybindings": [
      {
        "command": "taski.addTodayLog",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "taski.addTomorrowLog",
        "key": "ctrl+shift+y",
        "mac": "cmd+shift+y",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "taski.toggleTask",
        "key": "ctrl+shift+x",
        "mac": "cmd+shift+x",
        "when": "editorTextFocus && editorLangId == markdown"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "taski.refreshTasks",
          "when": "view == taskiView || view == taskiTagView",
          "group": "navigation"
        },
        {
          "command": "taski.syncNow",
          "when": "view == taskiView && config.taski.gitAutoSync",
          "group": "navigation"
        },
        {
          "command": "taski.showSchedule",
          "when": "view == taskiView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Taski",
      "properties": {
        "taski.includeWorkspace": {
          "type": "boolean",
          "default": false,
          "description": "現在のワークスペースをスキャン対象に含めるかどうか"
        },
        "taski.excludeDirectories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "スキャン対象から除外するディレクトリのglobパターン一覧（例: **/archive/**, **/backup/**）"
        },
        "taski.additionalDirectories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "追加でスキャンするディレクトリのパス一覧（絶対パス）"
        },
        "taski.taskAlert": {
          "type": "boolean",
          "default": true,
          "description": "タスクの開始時刻にアラート通知を表示する"
        },
        "taski.taskAlertLeadMinutes": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "maximum": 30,
          "description": "タスク開始の何分前にアラートを表示するか（デフォルト: 5分）"
        },
        "taski.gitAutoSync": {
          "type": "boolean",
          "default": true,
          "description": "$HOME/taskiディレクトリのGit自動同期を有効にする"
        },
        "taski.gitSyncInterval": {
          "type": "number",
          "default": 60,
          "minimum": 30,
          "description": "Git自動同期の間隔（秒）。最小30秒。"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "build:wasm": "cd parser-wasm && wasm-pack build --target nodejs --out-dir ../src/pkg",
    "compile": "npm run build:wasm && npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run build:wasm && npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run build:wasm && npm run compile-tests && cp -r src/pkg out/pkg && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "build:cli": "cd cli && cargo build --release",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
